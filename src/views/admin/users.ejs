<%- include('../partials/shell-start') %>
      <div class="flex flex-1 flex-col">
        <div class="flex items-center justify-between">
          <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-white">Users</h1>
          <a href="/admin" class="text-sm text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white">&larr; Overview</a>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <% users.forEach(function(u) { %>
            <div class="flex items-center justify-between card px-4 py-3">
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-neutral-900 dark:text-white">
                  <%= u.email %>
                  <% if (u.role === 'admin') { %>
                    <span class="ml-2 rounded-full bg-neutral-900 px-2 py-0.5 text-[10px] font-semibold uppercase text-white">Admin</span>
                  <% } %>
                  <% if (u.is_banned) { %>
                    <span class="ml-2 rounded-full bg-red-100 px-2 py-0.5 text-[10px] font-semibold uppercase text-red-600">Banned</span>
                  <% } %>
                </p>
                <p class="mt-0.5 text-xs text-neutral-400 dark:text-neutral-500">Joined <%= u.dateLabel %></p>
              </div>
              <% if (u.id !== user.sub) { %>
                <div class="ml-4 flex shrink-0 gap-3 text-xs font-medium">
                  <% if (u.is_banned) { %>
                    <form action="/admin/users/<%= u.id %>/unban" method="POST">
                      <button type="submit" class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white">Unban</button>
                    </form>
                  <% } else { %>
                    <form action="/admin/users/<%= u.id %>/ban" method="POST">
                      <button type="submit" class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white">Ban</button>
                    </form>
                  <% } %>
                  <form action="/admin/users/<%= u.id %>/delete" method="POST">
                    <button type="submit" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300">Delete</button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
<%- include('../partials/shell-end') %>
