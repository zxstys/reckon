<%- include('../partials/shell-start') %>
      <div class="flex flex-1 flex-col">
        <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-white">Admin overview</h1>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">A snapshot of this server.</p>

        <div class="mt-6 grid grid-cols-2 gap-3">
          <div class="card px-4 py-3">
            <p class="text-xs text-neutral-400 dark:text-neutral-500">Users</p>
            <p class="mt-1 text-xl font-semibold text-neutral-900 dark:text-white"><%= stats.userCount %></p>
          </div>
          <div class="card px-4 py-3">
            <p class="text-xs text-neutral-400 dark:text-neutral-500">Files</p>
            <p class="mt-1 text-xl font-semibold text-neutral-900 dark:text-white"><%= stats.fileCount %></p>
          </div>
          <div class="card px-4 py-3">
            <p class="text-xs text-neutral-400 dark:text-neutral-500">Storage used</p>
            <p class="mt-1 text-xl font-semibold text-neutral-900 dark:text-white"><%= stats.storageUsedLabel %></p>
          </div>
          <div class="card px-4 py-3">
            <p class="text-xs text-neutral-400 dark:text-neutral-500">Storage driver</p>
            <p class="mt-1 text-xl font-semibold uppercase text-neutral-900 dark:text-white"><%= stats.storageDriver %></p>
          </div>
        </div>

        <div class="mt-8 flex gap-3">
          <a href="/admin/users" class="btn-secondary">Manage users</a>
          <a href="/admin/files" class="btn-secondary">Manage files</a>
        </div>
      </div>
<%- include('../partials/shell-end') %>
