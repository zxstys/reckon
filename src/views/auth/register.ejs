<%- include('../partials/shell-start') %>
      <div class="flex flex-1 flex-col justify-center">
        <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-white">Create your account</h1>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Start uploading and sharing files in seconds.</p>

        <% if (error) { %>
          <div class="mt-5 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-600 dark:bg-red-500/10 dark:text-red-400"><%= error %></div>
        <% } %>

        <form action="/register" method="POST" class="mt-6 flex flex-col gap-4">
          <div>
            <label class="mb-1.5 block text-sm font-medium text-neutral-700 dark:text-neutral-300">Email</label>
            <input type="email" name="email" required class="input-field" placeholder="you@example.com" />
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-neutral-700 dark:text-neutral-300">Password</label>
            <input type="password" name="password" required minlength="8" class="input-field" placeholder="At least 8 characters" />
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-neutral-700 dark:text-neutral-300">Confirm password</label>
            <input type="password" name="confirmPassword" required minlength="8" class="input-field" placeholder="Repeat your password" />
          </div>
          <button type="submit" class="btn-primary mt-2 w-full">Create account</button>
        </form>

        <p class="mt-6 text-sm text-neutral-500 dark:text-neutral-400">
          Already have an account? <a href="/login" class="font-medium text-neutral-900 underline dark:text-white">Log in</a>
        </p>
      </div>
<%- include('../partials/shell-end') %>
