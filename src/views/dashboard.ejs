<%- include('partials/shell-start') %>
      <div class="flex flex-1 flex-col">
        <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-white">My files</h1>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Everything you've uploaded to <%= locals.appName || 'Reckon' %>.</p>

        <div class="mt-6 flex flex-col gap-3">
          <% if (files.length === 0) { %>
            <p class="rounded-2xl border border-dashed border-neutral-300 px-4 py-8 text-center text-sm text-neutral-400 dark:border-white/10 dark:text-neutral-500">
              You haven't uploaded any files yet.
            </p>
          <% } %>
          <% files.forEach(function(file) { %>
            <div class="card flex items-center justify-between px-4 py-3">
              <div class="min-w-0">
                <a href="/f/<%= file.id %>" class="block truncate text-sm font-medium text-neutral-900 hover:underline dark:text-white"><%= file.original_name %></a>
                <p class="mt-0.5 text-xs text-neutral-400 dark:text-neutral-500"><%= file.sizeLabel %> · <%= file.download_count %> downloads · <%= file.dateLabel %></p>
              </div>
              <form action="/dashboard/<%= file.id %>/delete" method="POST">
                <button type="submit" class="ml-4 shrink-0 text-xs font-medium text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300">Delete</button>
              </form>
            </div>
          <% }); %>
        </div>

        <a href="/" class="btn-primary mt-8 self-start">Upload a file</a>
      </div>
<%- include('partials/shell-end') %>
